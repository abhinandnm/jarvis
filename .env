# J.A.R.V.I.S. Local API Server Configuration
API_HOST=127.0.0.1
API_PORT=8000

# AI Provider ("gemini" | "openai" | "ollama")
AI_PROVIDER=gemini

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM Models
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Speech Providers
# STT_PROVIDER ("local" | "openai")
STT_PROVIDER=local
# TTS_PROVIDER ("edge-tts" | "local" | "openai")
TTS_PROVIDER=edge-tts
TTS_VOICE=en-US-GuyNeural

# Wake Word
WAKE_WORD=jarvis
